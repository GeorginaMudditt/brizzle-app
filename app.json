{
  "expo": {
    "name": "Brizzle",
    "slug": "brizzle",
    "scheme": "brizzle",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brizzle-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [],
      "package": "com.anonymous.brizzle"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "react-native-video",
      "expo-video"
    ]
  }
}
